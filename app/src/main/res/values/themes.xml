<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Mobilki" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">#FF5722</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Mobilki" parent="Base.Theme.Mobilki" />

    <style name="CalcButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_margin">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="CalcButton.Number">
        <item name="backgroundTint">#333333</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="CalcButton.Operator">
        <item name="backgroundTint">#FF9500</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="CalcButton.Function">
        <item name="backgroundTint">#A5A5A5</item>
        <item name="android:textColor">#000000</item>
    </style>
</resources>